    "# Visualize the distribution of HR, EDA, and TEMP for each nurse\n",
    "df['day'] = df[\"time\"].dt.day\n",
    "df['hour'] = df[\"time\"].dt.hour\n",
    "df['min'] = df[\"time\"].dt.minute\n",
    "\n",
    "for i in range (len(patients)):\n",
    "    \n",
    "    one_patient = df[df[\"id\"] == patients[i]]\n",
    "    for day in np.unique(one_patient[\"day\"]):\n",
    "        day_data = one_patient[one_patient[\"day\"] == day]\n",
    "        plt.hist(day_data[\"HR\"], bins = 50, alpha = 0.5)\n",
    "        plt.xlabel(\"HR\")\n",
    "        plt.ylabel(\"Frequency\")\n",
    "        plt.title(f\"Distribution of HR - Nurse {i+1} - Day {day}\")\n",
    "    plt.show()\n",
