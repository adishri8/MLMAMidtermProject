    "# Use precomputed hour for robust groupby\n",
    "# (do not assign inside loop to avoid SettingWithCopy warnings)\n",
    "# df['hour'] was set above in previous cell.\n",
    "stress = []\n",
    "hr = []\n",
    "for i in range (len(patients)):\n",
    "    one_patient = df[df[\"id\"] == patients[i]]\n",
    "    stress = []\n",
    "    hr = []\n",
    "    for min in np.unique(one_patient[\"min\"]):\n",
    "        avg_hr = one_patient[one_patient[\"min\"] == min][\"EDA\"].mean()\n",
    "        avg_stress = one_patient[one_patient[\"min\"] == min][\"label\"].mean()\n",
    "        stress.append(avg_stress)\n",
    "        hr.append(avg_hr)\n",
    "    plt.hist(stress, bins=50, color='orange')\n",
    "    plt.show()\n",
    "# plt.scatter(hr, stress)\n",
    "# plt.xlabel(\"Average HR\")\n",
    "# plt.ylabel(\"Average Stress\")\n",
    "# plt.title(f\"Nurse {i+1}'s Average HR vs Average Stress by Hour\")\n",
    "# plt.show()"
   ]
